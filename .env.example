# Transport
MCP_TRANSPORT=stdio           # stdio (Claude Desktop) or streamable-http (remote)
MCP_PORT=8000

# QuickBooks OAuth — get from developer.intuit.com
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_ENVIRONMENT=sandbox       # sandbox or production
QBO_REDIRECT_URI=http://localhost:8000/oauth/callback

# Safety defaults
DEFAULT_DRAFT_MODE=true

# Server
BASE_URL=http://localhost:8000
DB_PATH=./qbo_mcp.db
LOG_LEVEL=INFO
